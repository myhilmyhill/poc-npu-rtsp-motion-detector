# .env.example
# Copy this file to .env and customize the values

# RTSP Stream URL
RTSP_URL=test_data/motion_test.mp4
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1
RTSP_USERNAME=admin
RTSP_PASSWORD=secret

# Display settings (set to :0 if you want GUI in Docker)
DISPLAY=:0

# Model settings
USE_NPU=false
CONFIDENCE_THRESHOLD=0.5

# Logging level
LOG_LEVEL=INFO

# Display toggle (Docker usually runs headless)
DISPLAY_ENABLED=false
